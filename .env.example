# ============================================================
# IPL Franchise Analytics System — Environment Variables
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# ============================================================

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ipl_analytics
DB_USER=ipl_user
DB_PASSWORD=your_secure_password_here
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── API Security ──────────────────────────────────────────
JWT_SECRET_KEY=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
API_KEY=your_api_key_here

# ── FastAPI ────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_WORKERS=4

# ── Streamlit ─────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ── Email Alerts ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourfranchise.com
SMTP_PASSWORD=your_email_password
ALERT_RECIPIENTS=management@yourfranchise.com,cto@yourfranchise.com

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATION=midnight
LOG_RETENTION_DAYS=30

# ── ETL ───────────────────────────────────────────────────
ETL_BATCH_SIZE=1000
ETL_RETRY_ATTEMPTS=3
ETL_RETRY_DELAY_SECONDS=5
RAW_DATA_PATH=data/raw
STAGING_DATA_PATH=data/staging
PROCESSED_DATA_PATH=data/processed
CURATED_DATA_PATH=data/curated

# ── Environment ────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
